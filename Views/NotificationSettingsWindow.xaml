<Window x:Class="PanoramaFuturesAI.Views.NotificationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="通知推送设置"
        Height="720" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D1117">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6EDF3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E6EDF3"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#2EA043"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#30363D"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#161B22" Padding="20,16">
            <TextBlock Text="通知推送设置" FontSize="18" FontWeight="Bold"/>
        </Border>

        <!-- 设置内容 -->
        <ScrollViewer Grid.Row="1" Background="#0D1117" Padding="24">
            <StackPanel>
                <!-- ==================== 飞书卡片消息 ==================== -->
                <TextBlock Text="飞书卡片消息" FontSize="15" FontWeight="Bold" Foreground="#58A6FF" Margin="0,0,0,16"/>

                <!-- 飞书 Webhook -->
                <TextBlock Text="Webhook 地址" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                <TextBox x:Name="WebhookUrlBox" Text="{Binding WebhookUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                <TextBlock Text="在飞书群机器人设置中获取 Webhook 地址" Foreground="#484F58" FontSize="11" Margin="0,0,0,8"/>

                <CheckBox x:Name="EnabledCheckBox" IsChecked="{Binding Enabled}" Foreground="#E6EDF3" Margin="0,0,0,24">
                    <TextBlock Text="启用卡片消息推送" Foreground="#E6EDF3"/>
                </CheckBox>

                <!-- 分隔线 -->
                <Separator Background="#30363D" Margin="0,0,0,24"/>

                <!-- ==================== 飞书图片推送 ==================== -->
                <TextBlock Text="飞书图片推送" FontSize="15" FontWeight="Bold" Foreground="#58A6FF" Margin="0,0,0,16"/>

                <!-- App ID -->
                <TextBlock Text="App ID" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                <TextBox x:Name="ImageApiKeyBox" Text="{Binding ImageApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                <TextBlock Text="飞书应用的 App ID（从飞书开放平台获取）" Foreground="#484F58" FontSize="11" Margin="0,0,0,12"/>

                <!-- App Secret -->
                <TextBlock Text="App Secret" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                <TextBox x:Name="ImageSecretKeyBox" Text="{Binding ImageSecretKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                <TextBlock Text="飞书应用的 App Secret（从飞书开放平台获取）" Foreground="#484F58" FontSize="11" Margin="0,0,0,12"/>

                <!-- 接收者 ID -->
                <TextBlock Text="接收者 ID" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="ImageReceiverIdBox" Text="{Binding ImageReceiverId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1" x:Name="ImageReceiverIdTypeCombo" Width="100" SelectedValue="{Binding ImageReceiverIdType}" SelectedValuePath="Tag">
                        <ComboBoxItem Content="open_id" Tag="open_id"/>
                        <ComboBoxItem Content="user_id" Tag="user_id"/>
                        <ComboBoxItem Content="union_id" Tag="union_id"/>
                        <ComboBoxItem Content="chat_id" Tag="chat_id"/>
                    </ComboBox>
                </Grid>
                <TextBlock Text="用户的 ID 或群会话 ID（根据类型选择对应的 ID 格式）" Foreground="#484F58" FontSize="11" Margin="0,0,0,12"/>

                <!-- 图片推送启用 -->
                <CheckBox x:Name="ImagePushEnabledCheckBox" IsChecked="{Binding ImagePushEnabled}" Foreground="#E6EDF3" Margin="0,0,0,16">
                    <TextBlock Text="启用图片消息推送" Foreground="#E6EDF3"/>
                </CheckBox>

                <!-- 测试截图 -->
                <Button x:Name="TestScreenshotButton" Content="测试截图" Click="TestScreenshot_Click" Margin="0,0,0,8" HorizontalAlignment="Left"/>
                <TextBlock x:Name="ScreenshotPathText" Text="" Foreground="#8B949E" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <!-- 测试图片消息 -->
                <Button x:Name="TestImageButton" Content="测试图片消息" Click="TestImageMessage_Click" Margin="0,0,0,8" HorizontalAlignment="Left"/>
                <Button x:Name="TestButton" Content="测试 Webhook" Click="TestConnection_Click" Margin="0,0,0,8" HorizontalAlignment="Left"/>
                <TextBlock x:Name="TestResultText" Text="" Foreground="#3FB950" FontSize="12" Margin="0,0,0,16"/>

                <!-- 分隔线 -->
                <Separator Background="#30363D" Margin="0,0,0,24"/>

                <!-- ==================== 推送模式 ==================== -->
                <TextBlock Text="推送模式" FontSize="15" FontWeight="Bold" Foreground="#58A6FF" Margin="0,0,0,16"/>

                <!-- 推送模式 -->
                <StackPanel Margin="0,0,0,24">
                    <RadioButton x:Name="ModeManual" IsChecked="{Binding IsManualMode}" Foreground="#E6EDF3" Margin="0,0,0,8">
                        <RadioButton.Style>
                            <Style TargetType="RadioButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="radio" Width="18" Height="18" CornerRadius="9" BorderBrush="#30363D" BorderThickness="2" Background="#0D1117" Margin="0,0,8,0">
                                                    <Ellipse x:Name="dot" Width="8" Height="8" Fill="#58A6FF" Visibility="Collapsed"/>
                                                </Border>
                                                <TextBlock Text="手动推送（生成策略后自动推送）" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="radio" Property="BorderBrush" Value="#58A6FF"/>
                                                    <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </RadioButton.Style>
                    </RadioButton>
                    <RadioButton x:Name="ModeScheduled" IsChecked="{Binding IsScheduledMode}" Foreground="#E6EDF3">
                        <RadioButton.Style>
                            <Style TargetType="RadioButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="radio" Width="18" Height="18" CornerRadius="9" BorderBrush="#30363D" BorderThickness="2" Background="#0D1117" Margin="0,0,8,0">
                                                    <Ellipse x:Name="dot" Width="8" Height="8" Fill="#58A6FF" Visibility="Collapsed"/>
                                                </Border>
                                                <TextBlock Text="定时推送" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="radio" Property="BorderBrush" Value="#58A6FF"/>
                                                    <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </RadioButton.Style>
                    </RadioButton>
                </StackPanel>

                <!-- 定时设置（仅定时模式显示） -->
                <Border x:Name="ScheduledSettingsPanel" Background="#21262D" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="定时推送设置" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="推送时间: " Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" x:Name="HourComboBox" SelectedItem="{Binding SelectedHour}" Width="80"/>
                            <TextBlock Grid.Column="2" Text=" : " Foreground="#E6EDF3" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="推送周期: " Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="IntervalComboBox" SelectedItem="{Binding SelectedInterval}" Width="120"/>
                        </StackPanel>

                        <TextBlock x:Name="NextPushText" Text="" Foreground="#8B949E" FontSize="11" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 状态信息 -->
                <Border Background="#21262D" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="当前状态" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="StatusText" Text="通知服务已停止" Foreground="#8B949E" FontSize="12"/>
                        <TextBlock x:Name="LastPushText" Text="上次推送: 未推送" Foreground="#8B949E" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="#161B22" Padding="20,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="100" Margin="0,0,12,0" Click="CancelButton_Click"/>
                <Button Content="保存" Style="{StaticResource PrimaryButton}" Width="100" Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
