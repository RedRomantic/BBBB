<Window x:Class="PanoramaFuturesAI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PanoramaFuturesAI.Views"
        xmlns:converters="clr-namespace:PanoramaFuturesAI.Converters"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="全景合约市场 AI 决策系统"
        Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:PhaseToIconConverter x:Key="PhaseToIconConverter"/>
        <converters:PhaseToNameConverter x:Key="PhaseToNameConverter"/>
        <converters:PhaseToDescriptionConverter x:Key="PhaseToDescriptionConverter"/>
        <converters:PhaseToColorConverter x:Key="PhaseToColorConverter"/>
        <converters:BiasToTextConverter x:Key="BiasToTextConverter"/>
        <converters:BiasToColorConverter x:Key="BiasToColorConverter"/>
        <converters:RiskToTextConverter x:Key="RiskToTextConverter"/>
        <converters:RiskToColorConverter x:Key="RiskToColorConverter"/>
        <converters:ActionToColorConverter x:Key="ActionToColorConverter"/>
        <converters:ActionToTextConverter x:Key="ActionToTextConverter"/>
        <converters:ActionToIconConverter x:Key="ActionToIconConverter"/>

        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#E6EDF3"/></Style>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#2EA043"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="border" Property="Background" Value="#21262D"/><Setter Property="Foreground" Value="#484F58"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#30363D"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Foreground" Value="#484F58"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E6EDF3"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E6EDF3"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="EvidenceItem" TargetType="Border">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#161B22" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="刷新" Click="Refresh_Click" Cursor="Hand" Margin="0,0,12,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                <Setter Property="BorderBrush" Value="#30363D"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="16,8"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="0" Content="设置" Click="OpenSettings_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                <Setter Property="BorderBrush" Value="#30363D"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="16,8"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ProgressBar IsIndeterminate="{Binding IsLoading}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" Width="100" Height="4" Background="#30363D" Foreground="#58A6FF" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LoadingStatus}" Foreground="#8B949E" FontSize="12" VerticalAlignment="Center"/>
                    <Button Content="🔔 通知" Click="OpenNotificationSettings_Click" Margin="16,0,0,0" Cursor="Hand" ToolTip="通知推送设置">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                <Setter Property="BorderBrush" Value="#30363D"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#30363D"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="📋 日志" Click="OpenLogWindow_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                <Setter Property="BorderBrush" Value="#30363D"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#30363D"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="45*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="25*"/>
            </Grid.ColumnDefinitions>

            <!-- A区: AI策略输出屏 -->
        <Border Grid.Column="0" Style="{StaticResource PanelBorder}" x:Name="StrategyPanel">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Style="{StaticResource SectionTitle}" Text="AI 策略输出"/>

                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                            SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="#21262D"/>
                            <Setter Property="Foreground" Value="#8B949E"/>
                            <Setter Property="Padding" Value="16,8"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}" Margin="0,0,4,0">
                                            <ContentPresenter ContentSource="Header"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#0D1117"/>
                                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#30363D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- Tab 1: 量化策略看板 -->
                    <TabItem Header="📊 量化策略看板">
                        <Border Background="#0D1117" CornerRadius="0,0,6,6" Padding="16">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="StrategyContentPanel">
                                    <!-- 动作与策略总结 - 顶部大字显示 -->
                                    <Border Background="#21262D" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding StrategyResult.Action, Converter={StaticResource ActionToIconConverter}}"
                                                       FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding StrategyResult.Action, Converter={StaticResource ActionToTextConverter}}"
                                                       Foreground="{Binding StrategyResult.Action, Converter={StaticResource ActionToColorConverter}}"
                                                       FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding StrategyResult.StrategySummary}"
                                                       Foreground="#E6EDF3" FontSize="14" TextWrapping="Wrap"
                                                       TextAlignment="Center" Margin="0,8,0,0" MaxWidth="400"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- 图表区域 -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 风险等级仪表盘 -->
                                        <Border Grid.Column="0" Background="#21262D" CornerRadius="8" Padding="16">
                                            <StackPanel>
                                                <TextBlock Text="风险等级" Foreground="#8B949E" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                <lvc:PieChart Height="160"
                                                              Series="{Binding StrategyResult.RiskGaugeSeries}"
                                                              InitialRotation="-90"/>
                                                <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0">
                                                    <Run Text="{Binding StrategyResult.RiskLevel, Mode=OneWay}" Foreground="{Binding StrategyResult.RiskColor}" FontSize="24" FontWeight="Bold"/>
                                                    <Run Text="/100" Foreground="#8B949E" FontSize="12"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding StrategyResult.RiskDescription}" Foreground="#8B949E" FontSize="11" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- 建议仓位仪表盘 -->
                                        <Border Grid.Column="2" Background="#21262D" CornerRadius="8" Padding="16">
                                            <StackPanel>
                                                <TextBlock Text="建议仓位" Foreground="#8B949E" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                <lvc:PieChart Height="160"
                                                              Series="{Binding StrategyResult.PositionGaugeSeries}"
                                                              InitialRotation="-90"/>
                                                <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0">
                                                    <Run Text="{Binding StrategyResult.SuggestedPosition, StringFormat='{}{0:F1}', Mode=OneWay}" Foreground="#58A6FF" FontSize="24" FontWeight="Bold"/>
                                                    <Run Text="%" Foreground="#8B949E" FontSize="12"/>
                                                </TextBlock>
                                                <TextBlock Text="占总仓位比例" Foreground="#8B949E" FontSize="11" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- 置信度进度条 -->
                                    <Border Background="#21262D" CornerRadius="8" Padding="16">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="置信度" Foreground="#8B949E" FontSize="12" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Foreground="#3FB950" FontSize="18" FontWeight="Bold">
                                                        <Run Text="{Binding StrategyResult.Confidence, Mode=OneWay, StringFormat='{}{0}'}" Foreground="#3FB950" FontSize="18" FontWeight="Bold"/>
                                                    </TextBlock>
                                                    <TextBlock Text="%" Foreground="#8B949E" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                                </StackPanel>
                                            </Grid>
                                            <ProgressBar Value="{Binding StrategyResult.Confidence}" Maximum="100" Height="12"
                                                         Background="#30363D" Foreground="#3FB950" BorderThickness="0"/>
                                            <TextBlock Text="{Binding StrategyResult.ConfidenceDescription}" Foreground="#8B949E" FontSize="11" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- 无数据提示 -->
                                    <TextBlock Text="点击「生成策略」获取 AI 分析结果"
                                               Foreground="#484F58" FontSize="14"
                                               HorizontalAlignment="Center" Margin="0,40,0,0"
                                               Visibility="{Binding StrategyResult.IsParsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </TabItem>

                    <!-- Tab 2: AI推演原文 -->
                    <TabItem Header="📝 AI推演原文">
                        <Border Background="#0D1117" CornerRadius="0,0,6,6" Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding AIStrategyOutput}" Foreground="#E6EDF3" FontSize="13"
                                           FontFamily="Consolas, Microsoft YaHei" TextWrapping="Wrap" LineHeight="22"/>
                            </ScrollViewer>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- B/B2/C区: 归因与控制区 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="50*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="25*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- B区: 市场归因 -->
            <Border Grid.Row="0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource SectionTitle}" Text="市场归因分析"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding MarketOverview.EvidenceList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource EvidenceItem}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                            <Border Grid.Column="0" Grid.RowSpan="2" Background="#30363D" CornerRadius="4" Padding="8,4" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Type}" Foreground="#58A6FF" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding Description}" Foreground="#E6EDF3" FontSize="12" TextWrapping="Wrap"/>
                                            <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding Value}" Foreground="#3FB950" FontSize="13" FontWeight="Bold"/>
                                                <TextBlock Text=" (强度: " Foreground="#8B949E" FontSize="11"/>
                                                <TextBlock Text="{Binding Strength}" Foreground="#F0883E" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock Text="/10)" Foreground="#8B949E" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- B2区: 关键指标 -->
            <Border Grid.Row="2" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource SectionTitle}" Text="关键市场指标"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="全市场平均 ADX"/>
                                <TextBlock Grid.Column="1" Foreground="#E6EDF3" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Text="{Binding MarketOverview.AverageADX, StringFormat='{}{0:F1}'}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="突破 EMA20 合约占比"/>
                                <TextBlock Grid.Column="1" Foreground="#E6EDF3" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                    <Run Text="{Binding MarketOverview.PercentAboveEMA20, StringFormat='{}{0:F1}', Mode=OneWay}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="突破 EMA50 合约占比"/>
                                <TextBlock Grid.Column="1" Foreground="#E6EDF3" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                    <Run Text="{Binding MarketOverview.PercentAboveEMA50, StringFormat='{}{0:F1}', Mode=OneWay}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="突破 EMA200 合约占比"/>
                                <TextBlock Grid.Column="1" Foreground="#E6EDF3" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                    <Run Text="{Binding MarketOverview.PercentAboveEMA200, StringFormat='{}{0:F1}', Mode=OneWay}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="平均价格偏离 EMA20"/>
                                <TextBlock Grid.Column="1" Foreground="#E6EDF3" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                    <Run Text="{Binding MarketOverview.AveragePriceDeviationFromEMA20, StringFormat='{}{0:+0.00;-0.00;0.00}', Mode=OneWay}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="BBW 历史百分位"/>
                                <TextBlock Grid.Column="1" Foreground="#E6EDF3" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                    <Run Text="{Binding MarketOverview.BBWPercentile, StringFormat='{}{0:F1}', Mode=OneWay}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="平均资金费率"/>
                                <TextBlock Grid.Column="1" Foreground="#E6EDF3" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                    <Run Text="{Binding MarketOverview.AverageFundingRate, StringFormat='{}{0:+0.0000;-0.0000;0.0000}', Mode=OneWay}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="分析合约数量"/>
                                <TextBlock Grid.Column="1" Foreground="#E6EDF3" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Text="{Binding MarketOverview.AnalyzedContractCount}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- C区: 控制按钮 -->
            <Border Grid.Row="4" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="刷新数据" Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="生成策略" Style="{StaticResource PrimaryButton}" Command="{Binding GenerateStrategyCommand}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- D区: 全局市场趋势看板 -->
        <Border Grid.Column="4" Style="{StaticResource PanelBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Style="{StaticResource SectionTitle}" Text="全局市场趋势"/>
                <Border Grid.Row="1" Background="#21262D" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{Binding MarketOverview.CurrentPhase, Converter={StaticResource PhaseToIconConverter}}" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Text="{Binding MarketOverview.CurrentPhase, Converter={StaticResource PhaseToNameConverter}}" Foreground="{Binding MarketOverview.CurrentPhase, Converter={StaticResource PhaseToColorConverter}}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" Text="{Binding MarketOverview.CurrentPhase, Converter={StaticResource PhaseToDescriptionConverter}}" Foreground="#8B949E" FontSize="13" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#21262D" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="阶段匹配度"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{Binding MarketOverview.PhaseMatchScore, StringFormat='{}{0:F0}'}" Foreground="#58A6FF" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="%" Foreground="#58A6FF" FontSize="14" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Background="#21262D" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="市场偏向"/>
                                <TextBlock Grid.Column="1" Text="{Binding MarketOverview.MarketBias, Converter={StaticResource BiasToTextConverter}}" Foreground="{Binding MarketOverview.MarketBias, Converter={StaticResource BiasToColorConverter}}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Background="#21262D" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Text="风险等级"/>
                                <TextBlock Grid.Column="1" Text="{Binding MarketOverview.RiskLevel, Converter={StaticResource RiskToTextConverter}}" Foreground="{Binding MarketOverview.RiskLevel, Converter={StaticResource RiskToColorConverter}}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Background="#21262D" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="市场评述" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding MarketOverview.MarketCommentary}" Foreground="#E6EDF3" FontSize="12" TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
